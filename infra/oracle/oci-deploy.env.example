# Copy this file to the private environment folder outside the repository as
# `oci-deploy.env`, then chmod it to 600. The deployment wrapper reads only
# these literal key/value pairs; it never sources the file as shell code.
OCI_BACKEND_IP=<backend-host-ip>
OCI_FRONTEND_IP=<frontend-host-ip>
OCI_USER=ubuntu
SSH_KEY=/absolute/path/to/oci-deployment.key
SSH_KNOWN_HOSTS=/absolute/path/to/trusted-known_hosts
