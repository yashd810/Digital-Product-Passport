VITE_API_URL=https://api.example.com
VITE_PUBLIC_VIEWER_URL=https://viewer.example.com
BACKEND_API_UPSTREAM=https://api.example.com

# Deployment target:
# - all      = single-host stack
# - frontend = frontend/viewer/marketing host
# - backend  = backend/postgres/storage host
# Split OCI hosts must set their own target explicitly. Do not use `all`
# on a host that should only run one side of the stack.
DPP_DEPLOY_TARGET=all

FRONTEND_PORT=3000
PUBLIC_VIEWER_PORT=3004
BACKEND_PORT=3001
MARKETING_PORT=8080
POSTGRES_PORT=5432

DB_HOST=postgres
DB_NAME=dppSystem
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_64_HEX_CHARS
# These external Docker volume names are immutable production data identities.
# Never change either value during a normal restart or deployment. The deploy
# guard refuses a missing PostgreSQL volume unless an operator explicitly
# performs a documented first bootstrap or database reset.
COMPOSE_PROJECT_NAME=dpp
LOCAL_STORAGE_VOLUME_NAME=dppLocalStorageData
POSTGRES_VOLUME_NAME=dppPostgresData

# Generate distinct 256-bit values with:
# bash infra/oracle/generate-env-secrets.sh
# Do not reuse any of these values across purposes or environments.
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS
PEPPER_V1=REPLACE_WITH_A_DIFFERENT_64_HEX_CHARS
OTP_HMAC_SECRET=REPLACE_WITH_A_DIFFERENT_64_HEX_CHARS
REPOSITORY_FILE_LINK_SECRET=REPLACE_WITH_A_DIFFERENT_64_HEX_CHARS

# The generator prints a matching ES256 (P-256) PEM keypair escaped for dotenv.
# The private key must remain only in this mode-600 host environment file.
SIGNING_PRIVATE_KEY=REPLACE_WITH_ESCAPED_P256_PRIVATE_KEY
SIGNING_PUBLIC_KEY=REPLACE_WITH_ESCAPED_P256_PUBLIC_KEY

# Optional server-side credentials for scheduled ERP/API jobs. Values here are
# never returned to browsers; jobs store only a credentialRef such as erp-primary.
# ASSET_SOURCE_CREDENTIALS_JSON='{"erp-primary":{"companyIds":[1],"allowedUrls":["https://erp.example.com/api/items"],"allowedMethods":["GET"],"headers":{"Authorization":"Bearer REPLACE_ME"}}}'

SERVER_URL=https://api.example.com
APP_URL=https://app.example.com
MARKETING_URL=https://example.com
# The marketing image receives these three origins as explicit build arguments:
# MARKETING_URL, APP_URL (customer login), and SERVER_URL (contact API).
# The frontend QR guidance receives MARKETING_URL as VITE_MARKETING_URL.

NODE_ENV=production
# Normal production startup only verifies an existing schema. Apply schema
# changes explicitly with `node scripts/migrate-db.js` inside the backend
# container during a controlled deployment.
RUN_SCHEMA_MIGRATIONS=false
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=.example.com
# Include the marketing origin for its unauthenticated contact-form POSTs.
# Dashboard sessions are restricted to the authenticated application origin.
ALLOWED_ORIGINS=https://example.com,https://app.example.com,https://viewer.example.com
# Comma-separated public ERP/API hostnames. Schemes, ports, paths, wildcards,
# loopback hosts, and private-network targets are rejected.
ASSET_SOURCE_ALLOWED_HOSTS=erp.example.com

STORAGE_PROVIDER=s3
STORAGE_S3_REGION=eu-frankfurt-1
STORAGE_S3_BUCKET=dpp-prod
STORAGE_S3_ACCESS_KEY_ID=REPLACE_ME
STORAGE_S3_SECRET_ACCESS_KEY=REPLACE_ME
STORAGE_S3_ENDPOINT=https://YOUR_NAMESPACE.compat.objectstorage.eu-frankfurt-1.oci.customer-oci.com
# Keep this bucket private. Public symbol assets are served through the API allowlist.
STORAGE_S3_FORCE_PATH_STYLE=true

# Backup continuity policy for formal conformance evidence
BACKUP_PROVIDER_ENABLED=true
BACKUP_PROVIDER_REQUIRED=true
BACKUP_PROVIDER_KEY=REPLACE_WITH_BACKUP_PROVIDER_KEY
BACKUP_PROVIDER_OBJECT_PREFIX=backup-provider
BACKUP_PUBLIC_HANDOVER_AUTO_ENABLE=true
BACKUP_POLICY_RPO_MINUTES=15
BACKUP_POLICY_RTO_HOURS=4
BACKUP_POLICY_VERIFICATION_FREQUENCY=daily
BACKUP_POLICY_RESTORE_TEST_FREQUENCY=quarterly
BACKUP_POLICY_VERIFICATION_METHOD=Replicated backup objects are hash-verified against recorded payload hashes.
BACKUP_POLICY_RESTORE_TEST_METHOD=Perform a documented restore rehearsal from backup storage into a non-production environment.
BACKUP_LAST_RESTORE_DRILL_AT=
BACKUP_RESTORE_DRILL_EVIDENCE_URI=
BACKUP_ARCHIVAL_STORAGE_MODE=ociObjectStorageRetentionRule
BACKUP_ARCHIVAL_RETENTION_DAYS=2555
BACKUP_ARCHIVAL_IMMUTABILITY_EVIDENCE_URI=

# Host-level PostgreSQL backups use a separate OCI customer-secret pair and a
# separate bucket. Do not reuse STORAGE_S3_ACCESS_KEY_ID or
# STORAGE_S3_SECRET_ACCESS_KEY; scope this credential only to the backup bucket.
# Enable only after all DB_BACKUP_S3_* values below use the separate backup bucket and credential pair.
DB_BACKUP_ENABLED=false
DB_BACKUP_S3_ENDPOINT=https://YOUR_BACKUP_NAMESPACE.compat.objectstorage.eu-frankfurt-1.oci.customer-oci.com
DB_BACKUP_S3_REGION=eu-frankfurt-1
DB_BACKUP_S3_BUCKET=dpp-prod-db-backups
DB_BACKUP_S3_ACCESS_KEY_ID=REPLACE_WITH_DB_BACKUP_S3_ACCESS_KEY_ID
DB_BACKUP_S3_SECRET_ACCESS_KEY=REPLACE_WITH_DB_BACKUP_S3_SECRET_ACCESS_KEY
DB_BACKUP_S3_FORCE_PATH_STYLE=true
DB_BACKUP_S3_PREFIX=db-backups/postgres
DB_BACKUP_EVIDENCE_S3_PREFIX=db-backups/evidence/restore-drills
DB_BACKUP_RETENTION_COUNT=14

CACHE_PROVIDER=memory
# OAuth/OIDC providers default to the configured issuer/discovery origin. Add
# allowedEndpointOrigins only for documented additional IdP origins (for
# example a separate token/JWKS host). All production endpoints must be public
# HTTPS URLs; development loopback requires OAUTH_ALLOW_INSECURE_HTTP=true.
OAUTH_PROVIDERS_JSON=[]
