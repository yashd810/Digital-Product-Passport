VITE_API_URL=https://api.example.com
VITE_PUBLIC_VIEWER_URL=https://viewer.example.com

FRONTEND_PORT=3000
PUBLIC_VIEWER_PORT=3004
BACKEND_PORT=3001
ASSET_MANAGEMENT_PORT=3003
MARKETING_PORT=8080
POSTGRES_PORT=5432

DB_NAME=dpp_system
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_64_HEX_CHARS

SERVER_URL=https://api.example.com
APP_URL=https://app.example.com
ASSET_MANAGEMENT_URL=https://assets.example.com

NODE_ENV=production
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
ALLOWED_ORIGINS=https://app.example.com,https://viewer.example.com

# OCI Always Free edge recommendation:
# - Use `oci_nlb_passthrough` if you want OCI's Always Free Network Load Balancer
#   in front of the existing Caddy TLS edge with TCP/TLS passthrough on 443.
# - Use `oci_flexible_lb_offload` if you want OCI's Always Free Flexible Load Balancer
#   to terminate TLS with OCI Certificates and forward to the Oracle host.
OCI_EDGE_MODE=oci_nlb_passthrough
OCI_LB_HEALTHCHECK_PATH=/health
OCI_LB_HEALTHCHECK_PORT=3001
OCI_LB_HEALTHCHECK_PROTOCOL=HTTP

STORAGE_PROVIDER=s3
STORAGE_S3_REGION=eu-frankfurt-1
STORAGE_S3_BUCKET=dpp-prod
STORAGE_S3_ACCESS_KEY_ID=REPLACE_ME
STORAGE_S3_SECRET_ACCESS_KEY=REPLACE_ME
STORAGE_S3_ENDPOINT=https://YOUR_NAMESPACE.compat.objectstorage.eu-frankfurt-1.oci.customer-oci.com
STORAGE_S3_PUBLIC_BASE_URL=https://YOUR_NAMESPACE.compat.objectstorage.eu-frankfurt-1.oci.customer-oci.com/dpp-prod
STORAGE_S3_FORCE_PATH_STYLE=true

# Backup continuity policy for formal conformance evidence
BACKUP_PROVIDER_ENABLED=true
BACKUP_PROVIDER_KEY=oci-primary
BACKUP_PROVIDER_OBJECT_PREFIX=backup-provider
BACKUP_POLICY_RPO_MINUTES=15
BACKUP_POLICY_RTO_HOURS=4
BACKUP_POLICY_VERIFICATION_FREQUENCY=daily
BACKUP_POLICY_RESTORE_TEST_FREQUENCY=quarterly
BACKUP_POLICY_VERIFICATION_METHOD=Replicated backup objects are hash-verified against recorded payload hashes.
BACKUP_POLICY_RESTORE_TEST_METHOD=Perform a documented restore rehearsal from backup storage into a non-production environment.

CACHE_PROVIDER=memory
OAUTH_PROVIDERS_JSON=[]
