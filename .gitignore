# Dependencies
node_modules/
apps/*/node_modules/

# Build output
dist/
build/
apps/*/dist/

# Environment files — contain secrets, never commit these
.env
.env.prod
.env.local
.env.*.local
apps/backend-api/.env

# Vite cache
node_modules/.vite/
node_modules/.cache/
.vite/

# User-uploaded files (runtime data, not source code)
storage/local-storage/

# macOS
.DS_Store

# Logs
*.log
npm-debug.log*

# Editor / local tools
.vscode/
.idea/
.claude/
