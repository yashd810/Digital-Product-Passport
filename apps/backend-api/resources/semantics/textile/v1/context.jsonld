{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "id": "@id",
    "type": "@type",
    "textile": "https://www.claros-dpp.online/dictionary/textile/v1/terms/",
    "TextileClass": "https://www.claros-dpp.online/dictionary/textile/v1/classes/",
    "DigitalTextilePassport": "TextileClass:DigitalTextilePassport",
    "DigitalProductPassport": "dpp:DigitalProductPassport",
    "dcat": "http://www.w3.org/ns/dcat#",
    "dcterms": "http://purl.org/dc/terms/",
    "dpp": "https://schema.digitalproductpassport.eu/ns/dpp#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ManufacturingAndCare": "TextileClass:ManufacturingAndCare",
    "MaterialComposition": "TextileClass:MaterialComposition",
    "RestrictedSubstances": "TextileClass:RestrictedSubstances",
    "TextileProductPassport": "TextileClass:TextileProductPassport",
    "productModelIdentifier": {
      "@id": "textile:product-model-identifier",
      "@type": "xsd:string"
    },
    "fiberComposition": {
      "@id": "textile:fiber-composition",
      "@type": "xsd:string"
    },
    "recycledContentPercentage": {
      "@id": "textile:recycled-content-percentage",
      "@type": "xsd:decimal"
    },
    "fabricWeight": {
      "@id": "textile:fabric-weight",
      "@type": "xsd:decimal"
    },
    "countryOfOrigin": {
      "@id": "textile:country-of-origin",
      "@type": "xsd:string"
    },
    "careInstructions": {
      "@id": "textile:care-instructions",
      "@type": "xsd:string"
    },
    "durabilityScore": {
      "@id": "textile:durability-score",
      "@type": "xsd:integer"
    },
    "restrictedSubstancesDisclosure": {
      "@id": "textile:restricted-substances-disclosure",
      "@type": "xsd:string"
    }
  }
}
