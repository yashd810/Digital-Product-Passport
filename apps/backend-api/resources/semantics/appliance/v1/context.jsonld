{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "id": "@id",
    "type": "@type",
    "clarosAppliance": "https://www.claros-dpp.online/dictionary/appliance/v1/terms/",
    "clarosApplianceClass": "https://www.claros-dpp.online/dictionary/appliance/v1/classes/",
    "DigitalAppliancePassport": "clarosApplianceClass:DigitalAppliancePassport",
    "DigitalProductPassport": "dpp:DigitalProductPassport",
    "dcat": "http://www.w3.org/ns/dcat#",
    "dcterms": "http://purl.org/dc/terms/",
    "dpp": "https://schema.digitalproductpassport.eu/ns/dpp#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Compliance": "clarosApplianceClass:Compliance",
    "Performance": "clarosApplianceClass:Performance",
    "ProductIdentification": "clarosApplianceClass:ProductIdentification",
    "RepairAndService": "clarosApplianceClass:RepairAndService",
    "productModelIdentifier": {
      "@id": "clarosAppliance:product-model-identifier",
      "@type": "xsd:string"
    },
    "applianceCategory": {
      "@id": "clarosAppliance:appliance-category",
      "@type": "xsd:string"
    },
    "manufacturerName": {
      "@id": "clarosAppliance:manufacturer-name",
      "@type": "xsd:string"
    },
    "energyRating": {
      "@id": "clarosAppliance:energy-rating",
      "@type": "xsd:string"
    },
    "powerConsumption": {
      "@id": "clarosAppliance:power-consumption",
      "@type": "xsd:decimal"
    },
    "repairabilityScore": {
      "@id": "clarosAppliance:repairability-score",
      "@type": "xsd:decimal"
    },
    "sparePartsAvailability": {
      "@id": "clarosAppliance:spare-parts-availability",
      "@type": "xsd:string"
    },
    "complianceDeclaration": {
      "@id": "clarosAppliance:compliance-declaration",
      "@type": "xsd:string"
    }
  }
}
