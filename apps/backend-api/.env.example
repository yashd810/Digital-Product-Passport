# ─── DATABASE ────────────────────────────────────────────────────────────────
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dpp_system

# ─── SECURITY — required, must be changed before deploying ───────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_64_BYTE_HEX_STRING
PEPPER_V1=CHANGE_ME_GENERATE_A_64_BYTE_HEX_STRING

# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV=development          # Set to "production" in prod — enables HTTPS cookies, HSTS, CSRF, stricter guards
PORT=3001
SERVER_URL=http://localhost:3001
APP_URL=http://localhost:3000
ASSET_MANAGEMENT_URL=http://localhost:3003

# Optional explicit storage paths for Docker/container deployments
# LOCAL_STORAGE_DIR=/data
# FILES_DIR=/data/passport-files
# REPO_DIR=/data/repository-files
# UPLOADS_DIR=/data/uploads

# ─── STORAGE ─────────────────────────────────────────────────────────────────
# local | s3
STORAGE_PROVIDER=local

# S3-compatible object storage settings (required when STORAGE_PROVIDER=s3)
# STORAGE_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
# STORAGE_S3_REGION=eu-central-1
# STORAGE_S3_BUCKET=your-bucket-name
# STORAGE_S3_ACCESS_KEY_ID=your-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=your-secret-key
# STORAGE_S3_PUBLIC_BASE_URL=https://cdn.yourdomain.com
# STORAGE_S3_FORCE_PATH_STYLE=false

# ─── CACHE ───────────────────────────────────────────────────────────────────
# memory | none
CACHE_PROVIDER=memory

# ─── ENTERPRISE SSO / OIDC ───────────────────────────────────────────────────
# JSON array of OIDC provider configs. Example:
# OAUTH_PROVIDERS_JSON=[{"key":"entra","label":"Microsoft Entra ID","issuer":"https://login.microsoftonline.com/<tenant-id>/v2.0","clientId":"...","clientSecret":"...","scopes":["openid","profile","email"],"defaultCompanyId":1,"defaultRole":"viewer","autoLinkByEmail":true,"allowCreateUser":true,"ssoOnly":false,"allowedEmailDomains":["example.com"]}]
OAUTH_PROVIDERS_JSON=[]

# ─── COOKIES ─────────────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=dpp_session
# In production NODE_ENV, COOKIE_SECURE defaults to true and COOKIE_SAME_SITE defaults to "strict"
# Override only if needed:
# COOKIE_SECURE=false
# COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=.yourdomain.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (in addition to localhost defaults)
ALLOWED_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_FROM=your@gmail.com

# ─── CONTACT FORM ─────────────────────────────────────────────────────────────
# Email address that receives contact form submissions
ADMIN_EMAIL=admin@yourdomain.com

# ─── DIGITAL SIGNATURES (optional — ephemeral key generated if not set) ───────
# Generate with: node -e "const {generateKeyPairSync}=require('crypto'); const {privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}}); console.log(privateKey.replace(/\n/g,'\\n')); console.log(publicKey.replace(/\n/g,'\\n'));"
# SIGNING_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# SIGNING_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# ─── ASSET MANAGEMENT ─────────────────────────────────────────────────────────
# Shared secret for the asset management platform integration
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ASSET_MANAGEMENT_SHARED_SECRET=CHANGE_ME_GENERATE_A_32_BYTE_HEX_STRING

# Optional: comma-separated allowed hostnames for ERP/API source fetches
# ASSET_SOURCE_ALLOWED_HOSTS=erp.example.com,api.teamcenter.example.com

# ─── RATE LIMITS (optional — sensible defaults built in) ─────────────────────
# RATE_LIMIT_AUTH_MAX=8
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_PUBLIC_READ_MAX=120
# RATE_LIMIT_PUBLIC_READ_WINDOW_MS=60000
# RATE_LIMIT_PUBLIC_HEAVY_MAX=20
# RATE_LIMIT_API_KEY_READ_MAX=300
